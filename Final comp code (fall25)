// =======================
// True sweep search + small forward creep during sweep
// =======================
enum RobotMode { MODE_FOLLOW, MODE_SWEEP_SEARCH };
RobotMode mode = MODE_FOLLOW;

const float MAX_SWEEP_DEG = 60.0;        // sweep limit to one side
const int   SWEEP_HALF_PERIOD = 1200;    // slower turn while searching

// NEW: small forward movement during sweeping to help reacquire on bends
const float SWEEP_CREEP_MM = 0.75;         // move forward slightly after each sweep chunk
const int   SWEEP_CREEP_HALF_PERIOD = 800;

const float FORWARD_CREEP_MM = 1;      // fallback creep if both sweeps fail
const int   FORWARD_CREEP_HALF_PERIOD = 800;

bool lineDetected() {
  // Reacquired if ANY sensor sees the line again
  return (!LT_M) || (!LT_L) || (!LT_R);
}

// Helper: sweep in dir, but check sensors while sweeping.
// NEW: after each turn chunk, creep forward 2 mm (unless we already found the line)
bool sweepTurnAndCheck(int dirSign, float totalDeg) {
  // dirSign: -1 = left, +1 = right
  const float CHUNK_DEG = 3.0;
  float turned = 0.0;

  while (turned < totalDeg) {
    if (lineDetected()) return true;

    float stepDeg = min(CHUNK_DEG, totalDeg - turned);
    if (dirSign < 0) turnLeftWithMPU(stepDeg * TURN_CORRECTION_K, SWEEP_HALF_PERIOD);
    else             turnRightWithMPU(stepDeg * TURN_CORRECTION_K, SWEEP_HALF_PERIOD);

    turned += stepDeg;

    if (lineDetected()) return true;

    // NEW: slight forward creep to help re-find line on bends
    moveChassisDir(FORWARD, SWEEP_CREEP_MM, SWEEP_CREEP_HALF_PERIOD);

    if (lineDetected()) return true;
  }
  return lineDetected();
}

void startSweepSearchFromLastDirection() {
  mode = MODE_SWEEP_SEARCH;
}

int lastDirection = 100;

void setup() {

  Serial.begin(115200);

  pinMode(LT_R, INPUT);
  pinMode(LT_M, INPUT);
  pinMode(LT_L, INPUT);

  Wire.begin();
  Wire.setClock(400000);
  while (!Serial);
  while (Serial.available()) Serial.read();

  // Initialize MPU6050
  mpu.initialize();
  if (mpu.testConnection()) {
    Serial.println("MPU6050 connected");
    calibrateGyroZ();
  } else {
    Serial.println("MPU6050 DEAD");
  }

  // Initialize motor control pins
  pinMode(enablePin, OUTPUT); digitalWrite(enablePin, LOW);
  pinMode(detPin, INPUT); digitalWrite(detPin, HIGH);
  pinMode(StepX, OUTPUT); pinMode(DirX, OUTPUT);
  pinMode(StepY, OUTPUT); pinMode(DirY, OUTPUT);
  pinMode(StepZ, OUTPUT); pinMode(DirZ, OUTPUT);
  pinMode(StepA, OUTPUT); pinMode(DirA, OUTPUT);
  pinMode(BTN_PIN, INPUT_PULLUP);

  trackRotationStart();

  // Initialize distance sensor
  initializeDistanceSensor();

  // Servo
  servo.attach(27);
  servo.write(60);
  servo.write(90);

  //Limit switch
  pinMode(limitSwitch, INPUT_PULLUP);
}

void loop() {
  Serial.println("LOOP");
  trackRotationUpdate();

  if (!LT_M) {        // if M  = 0 (white), move forward
    mode = MODE_FOLLOW;
    Serial.println("FORWARD");
    moveChassisDir(FORWARD, 5, 500);
    lastDirection = 0;
  }
  else if (!LT_R) { // if the right sensor detects line, turn right
    mode = MODE_FOLLOW;
    Serial.println("RIGHT");
    turnRightWithMPU(1 * TURN_CORRECTION_K, 500);
    lastDirection = +1;
  }
  else if (!LT_L) { // if the left sensor detects line, turn right
    mode = MODE_FOLLOW;
    Serial.println("LEFT");
    turnLeftWithMPU(1 * TURN_CORRECTION_K, 500);
    lastDirection = -1;
  }
  else {
    // ===== LOST LINE: TRUE SWEEP SEARCH =====
    if (mode != MODE_SWEEP_SEARCH) {
      Serial.println("LOST LINE -> START SWEEP SEARCH");
      startSweepSearchFromLastDirection();
    }

    // Decide initial sweep direction from lastDirection
    // lastDirection: -1 = last saw left, +1 = last saw right, 0 = straight
    int primaryDir = +1; // default right
    if (lastDirection == -1) primaryDir = -1;
    else if (lastDirection == +1) primaryDir = +1;

    // 1) Sweep toward the last known side
    Serial.println("SWEEP 1...");
    bool found = sweepTurnAndCheck(primaryDir, MAX_SWEEP_DEG);
    if (found) {
      Serial.println("LINE REACQUIRED (SWEEP 1)!");
      mode = MODE_FOLLOW;
      return;
    }

    // 2) Sweep back past center to the other side
    Serial.println("SWEEP 2...");
    found = sweepTurnAndCheck(-primaryDir, 2.0 * MAX_SWEEP_DEG);
    if (found) {
      Serial.println("LINE REACQUIRED (SWEEP 2)!");
      mode = MODE_FOLLOW;
      return;
    }

    // 3) Fallback: creep forward a bit and try again next loop
    Serial.println("SWEEP FAILED -> CREEP FORWARD");
    moveChassisDir(FORWARD, FORWARD_CREEP_MM, FORWARD_CREEP_HALF_PERIOD);

    // stay in MODE_SWEEP_SEARCH and repeat
  }
}

void trackRotationStart() {
  totalGyroZ = 0;
  lastTime = millis();
  trackingRotation = true;
}

void trackRotationUpdate() {
  if (!trackingRotation) return;

  unsigned long now = millis();
  float dt = (now - lastTime) / 1000.0;
  lastTime = now;

  // 1) Read raw gyroscope values
  int16_t gz_raw = mpu.getRotationZ();

  // 2) Convert to ï¿½/s
  float rate = (gz_raw - gyroZ_offset) / 131.0;

  // ?? Stationary detection and raw data accumulation ??
  if (abs(rate) < MOTION_THRESHOLD) {
    if (!was_stationary) {
      was_stationary = true;
      stationary_time = now;
      biasAccumulatorRaw = 0;
      biasCountRaw = 0;
    }
    biasAccumulatorRaw += gz_raw;
    biasCountRaw++;

    if (now - stationary_time > 3000 && biasCountRaw > 0) {
      gyroZ_offset = biasAccumulatorRaw / biasCountRaw;
      stationary_time = now;
      biasAccumulatorRaw = 0;
      biasCountRaw = 0;
    }
    return;
  }
  was_stationary = false;

  totalGyroZ += rate * dt;
}

/**
 * Serial commands?F/B/SL/SR/ML/MR?
 */
void processChassisCommand(String cmd) {
  if (cmd.startsWith("V")) {
    current_half_period = cmd.substring(1).toInt();
    Serial.print("Speed set: half_period = ");
    Serial.print(current_half_period);
    Serial.println(" us");
  }
  else if (cmd.startsWith("F")) {
    int dist = cmd.substring(1).toInt();
    moveChassisDir(FORWARD, dist, current_half_period);
  }
  else if (cmd.startsWith("B")) {
    int dist = cmd.substring(1).toInt();
    moveChassisDir(BACKWARD, dist, current_half_period);
  }
  else if (cmd.startsWith("SL")) {
    int dist = cmd.substring(2).toInt();
    moveChassisSideways(LEFT, dist, current_half_period);
  }
  else if (cmd.startsWith("SR")) {
    int dist = cmd.substring(2).toInt();
    moveChassisSideways(RIGHT, dist, current_half_period);
  }
  else if (cmd.startsWith("ML")) {
    int angle = cmd.substring(2).toInt();
    turnLeftWithMPU(angle * TURN_CORRECTION_K, 100);
  }
  else if (cmd.startsWith("MR")) {
    int angle = cmd.substring(2).toInt();
    turnRightWithMPU(angle * TURN_CORRECTION_K, 100);
  }
  else if (cmd == "YAW") {
    Serial.print("IMU_YAW=");
    Serial.println(getYaw());
  }
  else if (cmd == "SCAN") {
    measureDistances();
  }
  else if (cmd == "S") {
    Serial.println("DONE");
  }
  else {
    Serial.println("?");
  }
}

float normalizeAngle(float angle) {
  angle = fmod(angle, 360.0);
  if (angle > 180.0)  angle -= 360.0;
  if (angle <= -180.0) angle += 360.0;
  return angle;
}

